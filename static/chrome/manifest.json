{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "description": "__MSG_extDescription__",
    "version": "2.0.0",
    "default_locale": "en",
    "homepage_url": "https://github.com/Hogwai/EngineBlock",
    "icons": {
        "16": "icon_16.png",
        "48": "icon_48.png",
        "128": "icon_128.png"
    },
    "content_scripts": [
        {
            "matches": ["https://*.lacentrale.fr/*"],
            "run_at": "document_idle",
            "js": ["content.js"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage",
        "activeTab",
        "webNavigation"
    ],
    "host_permissions": [
        "https://*.lacentrale.fr/*",
        "https://raw.githubusercontent.com/Hogwai/EngineBlock/*"
    ]
}
